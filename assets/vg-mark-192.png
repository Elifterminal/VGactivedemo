    <!-- Apply the saved theme + layout preset before first paint to avoid a
         flash of the defaults on load. Mirrors ThemeContext's/LayoutContext's
         LS keys + defaults (Windswept / standard) for first-time visitors. -->
    <script>
      (function () {
        try {
          var t = localStorage.getItem("vg_theme");
          document.documentElement.setAttribute("data-vg-theme", t || "windswept");
        } catch (e) {
          document.documentElement.setAttribute("data-vg-theme", "windswept");
        }
        try {
          var l = localStorage.getItem("vg_layout");
          // mirror src/lib/layouts.ts — IMMERSIVE is the default (Flouk
          // 2026-07-16: the eye-catcher is the first thing they see); an
          // explicit choice always wins, retired/unknown ids -> immersive.
          var ok = ["standard", "rail", "immersive"];
          var lay = ok.indexOf(l) !== -1 ? l : "immersive";
          document.documentElement.setAttribute("data-vg-layout", lay);
          // Immersive hero: start the emblem downloads WITH the HTML instead
          // of after React boots — kills the visible "symbol loads late" beat.
          if (lay === "immersive") {
            ["/vg-mark-3d.png", "/vg-mark-512.png"].forEach(function (href) {
              var lk = document.createElement("link");
              lk.rel = "preload"; lk.as = "image"; lk.href = href;
              document.head.appendChild(lk);
            });
          }
        } catch (e) {
          document.documentElement.setAttribute("data-vg-layout", "immersive");
        }
      })();
    </script>
